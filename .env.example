# URL base da API do backend (inclui /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# URL pública do site (usada em canonical, sitemap, robots, OpenGraph, JSON-LD)
# Produção: https://verticecripto.com.br
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Secret compartilhado com o backend para a rota POST /api/revalidate
# (revalidação on-demand do ISR). Deve ser igual ao configurado no backend.
REVALIDATE_SECRET=

# ID de medição do Google Analytics (ex.: G-XXXXXXXXXX). Opcional.
NEXT_PUBLIC_GA_ID=
